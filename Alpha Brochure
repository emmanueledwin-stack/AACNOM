<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8" />
<meta name="viewport" content="width=device-width, initial-scale=1.0" />
<title>Alpha India — Personalize Your Brochure</title>
<script src="https://cdnjs.cloudflare.com/ajax/libs/pdf-lib/1.17.1/pdf-lib.min.js"></script>
<style>
  * { box-sizing: border-box; }
  body {
    margin: 0;
    font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, Helvetica, Arial, sans-serif;
    background: linear-gradient(135deg, #e63946 0%, #b81d2a 100%);
    min-height: 100vh;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 24px;
    color: #1a1a1a;
  }
  .card {
    background: #fff;
    width: 100%;
    max-width: 520px;
    border-radius: 16px;
    box-shadow: 0 30px 60px rgba(0,0,0,0.25);
    overflow: hidden;
  }
  .card-header {
    background: #e63946;
    color: #fff;
    padding: 28px 32px 24px;
  }
  .card-header h1 {
    margin: 0 0 6px;
    font-size: 26px;
    letter-spacing: -0.3px;
  }
  .card-header p {
    margin: 0;
    opacity: 0.92;
    font-size: 14px;
  }
  .card-body {
    padding: 28px 32px;
  }
  .field { margin-bottom: 18px; }
  .field label {
    display: block;
    font-size: 13px;
    font-weight: 600;
    color: #444;
    margin-bottom: 6px;
  }
  .field input {
    width: 100%;
    padding: 12px 14px;
    border: 1.5px solid #d9d9d9;
    border-radius: 10px;
    font-size: 15px;
    font-family: inherit;
    transition: border-color 0.15s ease, box-shadow 0.15s ease;
    outline: none;
  }
  .field input:focus {
    border-color: #e63946;
    box-shadow: 0 0 0 3px rgba(230,57,70,0.15);
  }
  .actions {
    margin-top: 20px;
    display: flex;
    gap: 12px;
  }
  button {
    flex: 1;
    background: #e63946;
    color: #fff;
    border: none;
    padding: 14px 18px;
    border-radius: 10px;
    font-size: 15px;
    font-weight: 600;
    cursor: pointer;
    transition: background 0.15s ease, transform 0.05s ease;
    font-family: inherit;
  }
  button:hover:not(:disabled) { background: #c92a37; }
  button:active:not(:disabled) { transform: translateY(1px); }
  button:disabled { background: #cfcfcf; cursor: not-allowed; }
  button.secondary {
    background: #fff;
    color: #444;
    border: 1.5px solid #d9d9d9;
  }
  button.secondary:hover:not(:disabled) { background: #f7f7f7; }
  .status {
    margin-top: 14px;
    font-size: 13px;
    min-height: 18px;
    color: #2a7a3a;
  }
  .status.error { color: #b81d2a; }
  .footer {
    text-align: center;
    padding: 14px;
    font-size: 12px;
    color: #888;
    background: #fafafa;
    border-top: 1px solid #eee;
  }
  .footer a { color: #e63946; text-decoration: none; }
</style>
</head>
<body>
  <div class="card">
    <div class="card-header">
      <h1>Personalize Your Alpha Brochure</h1>
      <p>Add your details below and download a ready-to-share PDF.</p>
    </div>
    <div class="card-body">
      <div class="field">
        <label for="name">Name</label>
        <input id="name" type="text" placeholder="e.g. John Mathew" autocomplete="name" />
      </div>
      <div class="field">
        <label for="email">Email Id</label>
        <input id="email" type="email" placeholder="e.g. john@alpha.org" autocomplete="email" />
      </div>
      <div class="field">
        <label for="phone">Phone Number</label>
        <input id="phone" type="tel" placeholder="e.g. +91 98765 43210" autocomplete="tel" />
      </div>
      <div class="actions">
        <button class="secondary" id="clearBtn" type="button">Clear</button>
        <button id="downloadBtn" type="button">Download PDF</button>
      </div>
      <div class="status" id="status"></div>
    </div>
    <div class="footer">
      Alpha India &middot; <a href="https://india.alpha.org" target="_blank" rel="noopener">india.alpha.org</a>
    </div>
  </div>

<script>
const PDF_BASE64 = "";

function base64ToBytes(b64) {
  const binary = atob(b64);
  const len = binary.length;
  const bytes = new Uint8Array(len);
  for (let i = 0; i < len; i++) bytes[i] = binary.charCodeAt(i);
  return bytes;
}

function setStatus(msg, isError) {
  const el = document.getElementById('status');
  el.textContent = msg || '';
  el.className = 'status' + (isError ? ' error' : '');
}

function safeFilename(name) {
  const base = (name || 'Alpha-Brochure').trim().replace(/[^a-zA-Z0-9 _-]/g, '').replace(/\s+/g, '_');
  return (base || 'Alpha-Brochure') + '.pdf';
}

async function generatePdf() {
  const name = document.getElementById('name').value.trim();
  const email = document.getElementById('email').value.trim();
  const phone = document.getElementById('phone').value.trim();

  if (!name && !email && !phone) {
    setStatus('Please enter at least one field before downloading.', true);
    return;
  }

  const btn = document.getElementById('downloadBtn');
  btn.disabled = true;
  setStatus('Preparing your PDF...');

  try {
    const { PDFDocument, StandardFonts, rgb } = PDFLib;
    const bytes = base64ToBytes(PDF_BASE64);
    const pdfDoc = await PDFDocument.load(bytes);
    const pages = pdfDoc.getPages();
    const lastPage = pages[pages.length - 1];
    const font = await pdfDoc.embedFont(StandardFonts.Helvetica);

    const textColor = rgb(0.1, 0.1, 0.1);
    const size = 12;

    // Coordinates measured from the PDF (A4: 595.28 x 841.89)
    // Name field box, Email Id field box, Ph No field box on page 4
    if (name)  lastPage.drawText(name,  { x: 110, y: 118, size, font, color: textColor });
    if (email) lastPage.drawText(email, { x: 110, y: 82,  size, font, color: textColor });
    if (phone) lastPage.drawText(phone, { x: 110, y: 45,  size, font, color: textColor });

    const out = await pdfDoc.save();
    const blob = new Blob([out], { type: 'application/pdf' });
    const url = URL.createObjectURL(blob);
    const a = document.createElement('a');
    a.href = url;
    a.download = safeFilename(name);
    document.body.appendChild(a);
    a.click();
    document.body.removeChild(a);
    setTimeout(() => URL.revokeObjectURL(url), 2000);

    setStatus('Done! Your PDF has been downloaded.');
  } catch (err) {
    console.error(err);
    setStatus('Something went wrong: ' + (err.message || err), true);
  } finally {
    btn.disabled = false;
  }
}

document.getElementById('downloadBtn').addEventListener('click', generatePdf);
document.getElementById('clearBtn').addEventListener('click', () => {
  document.getElementById('name').value = '';
  document.getElementById('email').value = '';
  document.getElementById('phone').value = '';
  setStatus('');
});

[ 'name', 'email', 'phone' ].forEach(id => {
  document.getElementById(id).addEventListener('keydown', (e) => {
    if (e.key === 'Enter') generatePdf();
  });
});
</script>
</body>
</html>
